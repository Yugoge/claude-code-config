  "acceptance_criteria": [
    {
      "id": "AC1",
      "type": "data",
      "given": "command string 'python3 cleanup.py rm /tmp/old'",
      "when": "strip_non_executable_contexts() processes it",
      "then": "rm is NOT present as a standalone token in the stripped output (pattern '(^|[ \\t;|&(])rm\\s' does not match)",
      "check": {
        "call": "strip_non_executable_contexts('python3 cleanup.py rm /tmp/old')",
        "assert": "not re.search(r'(^|[ \\t;|&(])rm\\s', result)"
      },
      "ac_uid": "ac1_python3_rm_false_positive"
    },
    {
      "id": "AC2",
      "type": "data",
      "given": "command string containing a process substitution fragment where '<(rm' is a single word token (e.g. 'python3 script.py <(rm /tmp/x)')",
      "when": "strip_non_executable_contexts() processes it",
      "then": "the token containing '(' is NOT stripped; rm inside the process substitution fragment remains visible to the hook",
      "check": {
        "call": "strip_non_executable_contexts('python3 script.py <(rm /tmp/x)')",
        "assert": "re.search(r'(^|[ \\t;|&(])rm\\s', result)"
      },
      "ac_uid": "ac2_process_subst_not_masked"
    },
    {
      "id": "AC3",
      "type": "data",
      "given": "command string 'node script.js pkill happy'",
      "when": "strip_non_executable_contexts() processes it",
