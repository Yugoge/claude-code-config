[
  {
    "id": "AC1",
    "ac_uid": "deadcode_authflag_removed",
    "type": "data",
    "given": "The 3 hook files (hooks/pretool-write-guard.sh, hooks/pretool-bash-safety.sh, hooks/stop-cleanup-allowlist.sh) after dev applies changes",
    "when": "grep -rn -E 'bulk-allowed|bulk[- ]?auth|auth[- ]flag|bulk-commit-auth-flag' hooks/pretool-write-guard.sh hooks/pretool-bash-safety.sh hooks/stop-cleanup-allowlist.sh",
    "then": "Exit code is 1 (no matches) and stdout is empty",
    "check": {
      "command": "grep -rn -E 'bulk-allowed|bulk[- ]?auth|auth[- ]flag|bulk-commit-auth-flag' hooks/pretool-write-guard.sh hooks/pretool-bash-safety.sh hooks/stop-cleanup-allowlist.sh",
      "expected_exit_code": 1,
      "expected_stdout": ""
    }
  },
  {
    "id": "AC2",
    "ac_uid": "sentinel_deny_preserved",
    "type": "data",
    "given": "hooks/pretool-write-guard.sh and hooks/pretool-bash-safety.sh after dev applies changes",
    "when": "grep -c 'claude-bulk-commit-sentinel' hooks/pretool-write-guard.sh hooks/pretool-bash-safety.sh",
    "then": "Both files return count >= 1 (sentinel protection is preserved)",
    "check": {
      "command": "grep -c 'claude-bulk-commit-sentinel' hooks/pretool-write-guard.sh hooks/pretool-bash-safety.sh",
      "expected_exit_code": 0,
      "expected_min_count_per_file": 1
    }
  }
]
