# Claude Code .gitignore

# Credentials and secrets
.credentials.json
*.key
*.pem

# Local settings (user-specific)
settings.local.json

# Temporary files
*.tmp
*.log

# Session data (may contain sensitive tokens)
todos/
shell-snapshots/
debug/
projects/

# Plugin data (may contain tokens)
plugins/
statsig/

# History
history.jsonl

# Node modules (if any)
node_modules/

# Python virtual environments
venv/
env/
.venv/
*.pyc
__pycache__/

# OS files
.DS_Store
Thumbs.db

# Backups
*.backup
*.bak

logs/*
# PERMITTED DELIVERY PATH: logs/lifecycle.jsonl is the R9 in-repo lifecycle log (spec-20260520-221059 binding constraint)
session-env/
systemd/

# File history (contains session data, may include secrets)
file-history/

# doc-sync runtime cache
.doc-sync-cache.json

# MCP auth runtime cache
mcp-needs-auth-cache.json

# Live session telemetry (was previously tracked; rm --cached old ones)
sessions/

# Dev cycle output and session state (not for version control)
.last-cleanup
playwright-storage-state.json
.todos.json
docs/*
# PERMITTED DELIVERY PATH: docs/reference/ holds in-repo documentation deliverables (arch-1/D3, spec-20260520-221059)
!docs/reference/

# Live workflow / dev coordination state
workflow-*.json
dev-registry/
specs/*/cp-state-*.json

# Spec checkpoint state, worktrees, and rotating .claude.json backups
specs/spec-*/
worktrees/
backups/.claude.json.backup.*
settings.json.bak-*

# Runtime telemetry (spec-20260518-225715 Cycle 2 P2.3 — root-anchored;
# previously leaked because the generic specs/spec-*/ rule above is relative
# and does not match .claude/specs/...)
/agent-scores.json
/agent-scores.json.lock
/.claude/specs/spec-*/

# Harness-generated output (transient per-cycle; not for version control)
# tests/generated/ intentionally tracked — test-writer contract version-controls per-cycle pytest files
# but _work/ is pytest RUNTIME SCRATCH (ac_harness.py WORKBASE; recreated every run,
# incl. nested throwaway git repos) and must NEVER be committed for any task
tests/generated/*/_work/
docs/codex/
.playwright-mcp/

# dot-claude-specific: screenshots from browser tools (not propagated to child repos)
*.png
# harness-propagated by session-gitignore-propagate.sh
.claude/dev-registry/dev-*/

# Graphify knowledge graph transient output (spec-20260527-061433)
graphify-out/

# dev workflow artifacts — never tracked (global policy)
docs/dev/

# Runtime/transient dirs (global no-track policy)
archive/
backups/
cache/
eval/
logs/
paste-cache/
plans/
specs/
state/
tasks/
