        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-todo-tracker.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-todo-count.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-todo-sequence.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-overnight-loop.py\""
