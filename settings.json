            "command": "python3 \"$HOME/.claude/hooks/pretool-claude-config-guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-bulk-commit-detector.py\"",
            "timeout": 5
          }
        ]
      },
      {
