      "Bash(python3 /root/.claude/scripts/spec-check.py:*)",
      "Bash(python3 /root/.claude/scripts/spec-verify/spec-verify-views.py:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 /root/.claude/scripts/spec-verify/spec-verify.py:*)",
      "Bash(scripts/validate-dev-registry-enforcement.sh:*)",
