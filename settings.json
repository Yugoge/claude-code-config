  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-info.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-git-init.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/check-todo-md-sync.py\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-promote-hook.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/scripts/canary-verify.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-tmpfs-banner.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-gitignore-propagate.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/prompt-workflow.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/userprompt-doc-sync-check.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/prehook-overnight-worktree-check.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/userprompt-consent-allowlist.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/userprompt-tmpfs-pressure.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-orchestrator-gate.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-read-size-guard.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-workflow-gate.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-subagent-enforce.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-bash-safety.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-bash-views-guard.py\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-cp-checkin.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-overnight-hook-guard.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-quality-gate.py\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-tool-policy.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-cp-state-write-guard.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-subagent-code-block.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-block-production-files.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_navigate|mcp__playwright__browser_click|mcp__playwright__browser_run_code|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-block-production.sh\""
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-todo-validate.py\""
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-block-enterworktree.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-worktree-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pretool-write-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
