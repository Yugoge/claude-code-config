{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "0",
    "MAX_MCP_OUTPUT_TOKENS": "40000",
    "EDITOR": "nano",
    "LANG": "en_US.UTF-8",
    "GIT_AUTO_STAGE_ALL": "0",
    "GIT_BLOCK_ON_UNTRACKED": "0",
    "GIT_WARN_UNTRACKED": "1",
    "GIT_PUSH_AUTO_STAGE": "1",
    "GIT_AUTO_PUSH": "1",
    "GIT_CHECKPOINT_THRESHOLD": "10",
    "GIT_CHECKPOINT_SILENT": "0",
    "PLAYWRIGHT_MCP_SANDBOX": "false",
    "PLAYWRIGHT_RUNCODE_TIMEOUT": "120",
    "ENABLE_TOOL_SEARCH": "false",
    "CLAUDE_CODE_ENABLE_TASKS": "false",
    "CLAUDE_GRAPHIFY_ENABLED": "auto",
    "_comment_graphify": "Graphify override env vars (leave unset to use defaults): GRAPHIFY_BIN=<path> overrides graphify CLI; CLAUDE_GRAPHIFY_CACHE_ROOT=<dir> overrides /var/tmp/claude-graphify",
    "_comment_anthropic": "以下为可选配置（已禁用）",
    "_disabled_anthropic": "[object Object]"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
