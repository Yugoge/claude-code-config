          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-orchestrator-prompt-purity.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-aggregate-check.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-gitignore-preflight.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_run_code",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-runcode-watchdog.py\""
