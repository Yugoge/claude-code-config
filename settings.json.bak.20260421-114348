{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "0",
    "MAX_MCP_OUTPUT_TOKENS": "40000",
    "EDITOR": "nano",
    "LANG": "en_US.UTF-8",
    "GIT_AUTO_STAGE_ALL": "0",
    "GIT_BLOCK_ON_UNTRACKED": "0",
    "GIT_WARN_UNTRACKED": "1",
    "GIT_PUSH_AUTO_STAGE": "1",
    "GIT_AUTO_PUSH": "1",
    "GIT_CHECKPOINT_THRESHOLD": "10",
    "GIT_CHECKPOINT_SILENT": "0",
    "PLAYWRIGHT_MCP_SANDBOX": "false",
    "PLAYWRIGHT_RUNCODE_TIMEOUT": "120",
    "ENABLE_TOOL_SEARCH": "false",
    "_comment_anthropic": "以下为可选配置（已禁用）",
    "_disabled_anthropic": "[object Object]"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "SlashCommand",
      "Bash(gh auth:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(cat > /tmp/*.json:*)",
      "Bash(cat > /tmp/*.txt:*)",
      "Bash(cat > /tmp/*.py:*)",
      "Bash(cat > /tmp/*.md:*)",
      "Bash(source venv/bin/activate:*)",
      "Bash(source venv/bin/activate && python*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(xargs:*)",
      "Bash(test:*)",
      "Bash(bash:*)",
      "Bash(for:*)",
      "Bash(do)",
      "Bash(done)",
      "Bash(if:*)",
      "Bash(then)",
      "Bash(else)",
      "Bash(fi)",
      "Bash(md5sum:*)",
      "Bash(lsof:*)",
      "Bash(tee:*)",
      "Bash(date:*)",
      "Bash(rm -f /tmp/*.pdf:*)",
      "Bash(rm -f /tmp/*.tmp:*)",
      "Bash(rm -f /tmp/*.json:*)",
      "Bash(rm:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 ~/.claude/scripts/todo/clean.py:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 ~/.claude/scripts/todo/test.py:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 ~/.claude/scripts/todo/quick-prototype.py:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 ~/.claude/scripts/todo/file-analyze.py:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 ~/.claude/scripts/todo/reflect-search.py:*)",
      "Bash(source ~/.claude/venv/bin/activate && python3 ~/.claude/tests/scripts/validate-*.py:*)",
      "Bash(~/.claude/scripts/orchestrator.sh clean-inspect:*)",
      "Bash(~/.claude/scripts/orchestrator.sh clean-merge-reports:*)",
      "Bash(~/.claude/scripts/orchestrator.sh clean-execute:*)",
      "Bash(~/.claude/scripts/orchestrator.sh record-checkpoint:*)",
      "Bash(~/.claude/scripts/orchestrator.sh rule-inspect:*)",
      "Bash(~/.claude/scripts/scan-project.sh:*)",
      "Bash(~/.claude/scripts/detect-orphan-scripts.sh:*)",
      "Bash(~/.claude/scripts/detect-orphan-agents.sh:*)",
      "Bash(~/.claude/scripts/detect-orphan-commands.sh:*)",
      "Bash(~/.claude/scripts/check-overnight-reports.sh:*)",
      "Bash(scripts/discover-folders.sh:*)",
      "Bash(scripts/analyze-folder-history.sh:*)",
      "Bash(scripts/generate-folder-index.sh:*)",
      "Bash(scripts/generate-folder-readme.sh:*)",
      "Bash(scripts/checkpoint-prune.sh:*)",
      "Bash(scripts/install-checkpoint-refspec.sh:*)",
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "SlashCommand",
      "Task",
      "TodoWrite",
      "Write(learning-materials/**)",
      "Write(knowledge-base/**)",
      "Write(.review/**)",
      "Write(chats/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(/tmp/**)",
      "Write(data/**)",
      "Edit(data/**)",
      "Edit(learning-materials/**)",
      "Edit(knowledge-base/**)",
      "Edit(.review/**)",
      "Edit(scripts/**)",
      "Edit(docs/**)",
      "Read(/root/**)",
      "Read(/tmp/**)",
      "mcp__memory-server__read_graph",
      "mcp__memory-server__create_entities",
      "mcp__memory-server__search_nodes",
      "mcp__memory-server__delete_entities",
      "mcp__memory-server__create_relations",
      "mcp__memory-server__add_observations",
      "mcp__memory-server__delete_observations",
      "mcp__memory-server__delete_relations",
      "mcp__memory-server__open_nodes",
      "mcp__happy__change_title",
      "mcp__playwright__*",
      "Bash(source venv/bin/activate && python scripts/analyze/analyze_spending.py:*)",
      "Bash(source venv/bin/activate && python scripts/add-status-field.py:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/*secret*)",
      "Read(**/*password*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Write(.env)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/credentials*)",
      "Write(**/*secret*)",
      "Write(**/*password*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(systemctl stop:*)",
      "Bash(systemctl disable:*)",
      "Read(**/session_dirs.txt)",
      "Write(**/session_dirs.txt)",
      "Edit(**/session_dirs.txt)",
      "Bash(*session_dirs.txt*)",
      "Bash(*happy-session-recovery*)",
      "Bash(*happy-restart*)",
      "Bash(curl:* | sh:*)",
      "Bash(wget:* | sh:*)",
      "Bash(sudo:*)",
      "Bash(su:*)"
    ],
    "ask": [
      "Bash(docker run:*)",
      "Bash(docker exec:*)",
      "Bash(docker rm:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl create:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Write(**/package.json)",
      "Edit(**/package.json)",
      "Write(**/pyproject.toml)",
      "Edit(**/pyproject.toml)",
      "Write(**/Cargo.toml)",
      "Edit(**/Cargo.toml)",
      "Write(**/go.mod)",
      "Edit(**/go.mod)",
      "Write(**/requirements.txt)",
      "Edit(**/requirements.txt)",
      "Write(.claude/commands/**)",
      "Edit(.claude/commands/**)",
      "Write(.claude/agents/**)",
      "Edit(.claude/agents/**)",
      "Write(.claude/hooks/**)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/scripts/**)",
      "Edit(.claude/scripts/**)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/CLAUDE.md)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-info.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-git-init.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/check-todo-md-sync.py\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-promote-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/prompt-workflow.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/userprompt-doc-sync-check.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-orchestrator-gate.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-read-size-guard.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-workflow-gate.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-subagent-enforce.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-bash-safety.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-overnight-hook-guard.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-quality-gate.py\""
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-todo-validate.py\""
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-block-enterworktree.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-worktree-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pretool-write-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-layer-escalation-check.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-bisect-gate.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-spec-block-foreground-agent.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_run_code",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/pretool-runcode-watchdog.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-todo-tracker.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-todo-count.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-todo-sequence.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-overnight-loop.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/posttool-git-checkpoint.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-doc-sync.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-command-frontmatter-validate.py\""
          }
        ]
      },
      {
        "matcher": "Bash\\(git commit.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/posttool-git-warn.sh\""
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-overnight-file-check.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-subagent-track.py\""
          }
        ]
      },
      {
        "matcher": "mcp__playwright__browser_run_code",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/posttool-runcode-watchdog.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/stop-overnight-timelock.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/stop-workflow-enforce.py\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/stop-git-commit.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/auto-commit.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/subagent-stop-diff-check.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-layer-match-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/subagent-stop-guard-integrity.sh\""
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
