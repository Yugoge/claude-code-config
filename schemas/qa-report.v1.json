{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa-report.v1",
  "title": "QA Report",
  "description": "QA verdict + evidence summary for a single pipeline. When ui_pipeline=true, evidence_summary.ui_evidence MUST satisfy the ui-specialist's ui_evidence_schema fragment (target_route, target_element, viewports {desktop, mobile}, evidence_map keyed AC-N, trace, captured_at). Custom keyword 'required_when_ui' is enforced by lib/contract_runtime.validate() as a pre-validation pass before the standard jsonschema Draft7Validator runs.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_version",
    "task_id",
    "verdict",
    "evidence_summary",
    "ui_pipeline"
  ],
  "properties": {
    "report_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "warning", "fail"]
    },
    "ui_pipeline": {
      "type": "boolean",
      "default": false
    },
    "evidence_summary": {
      "type": "object",
      "additionalProperties": true,
      "required_when_ui": ["ui_evidence"],
      "properties": {
        "ui_evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "target_route",
            "target_element",
            "viewports",
            "evidence_map",
            "trace",
            "captured_at"
          ],
          "properties": {
            "target_route": {
              "type": "string",
              "pattern": "^/.*"
            },
            "target_element": {
              "type": "object",
              "required": ["selector", "selector_type"],
              "properties": {
                "selector": {"type": "string", "minLength": 1},
                "selector_type": {
                  "type": "string",
                  "enum": ["data-testid", "role", "css", "xpath"]
                },
                "selector_justification": {"type": "string"},
                "label_for_humans": {"type": "string"}
              }
            },
            "viewports": {
              "type": "object",
              "required": ["desktop", "mobile"],
              "properties": {
                "desktop": {
                  "type": "object",
                  "required": ["viewport", "screenshot", "dom_measurement"],
                  "properties": {
                    "viewport": {
                      "type": "object",
                      "required": ["width", "height"],
                      "properties": {
                        "width": {"type": "integer", "minimum": 1280, "maximum": 1920, "default": 1440},
                        "height": {"type": "integer", "minimum": 720, "maximum": 1200, "default": 900}
                      }
                    },
                    "screenshot": {
                      "type": "string",
                      "pattern": ".*\\.(png|jpg|jpeg)$"
                    },
                    "dom_measurement": {"type": ["array", "object"]}
                  }
                },
                "mobile": {
                  "type": "object",
                  "required": ["viewport", "screenshot", "dom_measurement"],
                  "properties": {
                    "viewport": {
                      "type": "object",
                      "required": ["width", "height"],
                      "properties": {
                        "width": {"type": "integer", "minimum": 320, "maximum": 430, "default": 390},
                        "height": {"type": "integer", "minimum": 568, "maximum": 932, "default": 844}
                      }
                    },
                    "screenshot": {
                      "type": "string",
                      "pattern": ".*\\.(png|jpg|jpeg)$"
                    },
                    "dom_measurement": {"type": ["array", "object"]}
                  }
                }
              }
            },
            "evidence_map": {
              "type": "object",
              "patternProperties": {
                "^AC-[0-9]+[a-z]?$": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "description": "Path to an evidence artifact (screenshot, trace, dom-measurement record, log file)."
                  }
                }
              },
              "additionalProperties": false
            },
            "trace": {
              "type": "string",
              "pattern": ".*\\.zip$",
              "description": "Playwright trace.zip path relative to project root."
            },
            "captured_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "graph_verification": {
      "type": "object",
      "additionalProperties": true,
      "description": "QA graph verification summary (v1: presence check only — full graph diff deferred). Present when graphify enrichment ran.",
      "properties": {
        "graphify_ran": {"type": "boolean"},
        "graph_context_status": {"type": "string", "enum": ["ok", "degraded", "failed", "unavailable", "skipped"]},
        "focused_subgraph_present": {"type": "boolean"},
        "graph_report_present": {"type": "boolean"},
        "verification_note": {"type": "string", "description": "QA note on graph context quality"}
      }
    },
    "ac_status": {
      "type": "object",
      "patternProperties": {
        "^AC-?[0-9]+[a-z]?$": {
          "type": "string",
          "enum": ["met", "not_met", "n/a"]
        }
      }
    },
    "focus_criteria_results": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "criteria_provided": {"type": "boolean"},
        "criteria_count": {"type": "integer", "minimum": 0},
        "all_passed": {"type": "boolean"},
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["criterion", "result", "evidence", "severity", "evidence_level"],
            "properties": {
              "criterion": {"type": "string", "minLength": 1},
              "result": {"type": "string", "enum": ["pass", "fail", "warning", "skipped"]},
              "evidence": {"type": "string"},
              "severity": {"type": "string"},
              "evidence_level": {
                "type": "string",
                "enum": [
                  "rendered_cached",
                  "fresh_scan_triggered",
                  "fresh_scan_completed",
                  "extraction_verified"
                ]
              },
              "required_evidence_level": {
                "type": "string",
                "enum": [
                  "rendered_cached",
                  "fresh_scan_triggered",
                  "fresh_scan_completed",
                  "extraction_verified"
                ]
              }
            }
          }
        }
      }
    }
  }
}
