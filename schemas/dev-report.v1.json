{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dev-report.v1",
  "title": "Dev Report",
  "description": "Per-task dev implementation report. Read by QA, PM RETRO, and the closeout aggregator.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_version",
    "task_id",
    "status",
    "files_modified",
    "files_created",
    "root_cause_addressed",
    "ac_status"
  ],
  "properties": {
    "report_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "partial"]
    },
    "files_modified": {
      "type": "array",
      "items": {"type": "string"}
    },
    "files_created": {
      "type": "array",
      "items": {"type": "string"}
    },
    "root_cause_addressed": {
      "type": "string",
      "minLength": 1,
      "description": "1-3 sentence explanation of how the change addresses the BA-identified root cause."
    },
    "ac_status": {
      "type": "object",
      "patternProperties": {
        "^AC-?[0-9]+[a-z]?$": {
          "type": "string",
          "enum": ["met", "not_met", "n/a"]
        }
      }
    },
    "blast_radius": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["modified", "imported_by"],
        "properties": {
          "modified": {"type": "string"},
          "imported_by": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "self_verification": {
      "type": "object",
      "properties": {
        "build": {"type": "string", "enum": ["pass", "fail", "skipped"]},
        "smoke_check": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "implementation_notes": {
      "type": "string"
    }
  }
}
