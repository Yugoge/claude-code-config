{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-plan.v1",
  "title": "PM Test Plan",
  "description": "Unified PM-produced test plan. This schema replaces both legacy 'test-plan.json' and 'test-plan-*.json' shapes (per spec-20260426-090235 Section 7 P2 #3 — single canonical naming). additionalProperties:true preserves the existing rich PM payload (priority_tiers, recommended_specialists, pm_experience, app_context, agent_assignments, core_flow_gate, ...).",
  "type": "object",
  "additionalProperties": true,
  "required": ["plan_version", "pipelines", "generated_at"],
  "properties": {
    "plan_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "session_id": {"type": "string"},
    "cycle_id": {"type": "integer"},
    "pipelines": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["pipeline_id", "focus_string", "priority", "specialist_assignment"],
        "properties": {
          "pipeline_id": {"type": "string", "minLength": 1},
          "focus_string": {
            "type": "string",
            "enum": ["ui_design", "ui_audit", "backend", "infra", "docs", "bug_fix", "other"]
          },
          "priority": {"type": "integer"},
          "tier": {"type": ["integer", "string"]},
          "specialist_assignment": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "ba": {"type": ["string", "boolean", "object", "null"]},
              "dev": {"type": ["string", "boolean", "object", "null"]},
              "qa": {"type": ["string", "boolean", "object", "null"]},
              "specialists": {"type": "array"}
            }
          },
          "ui_evidence_required": {"type": "boolean"}
        }
      }
    },
    "recommended_specialists": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type"],
        "properties": {
          "type": {"type": "string"},
          "reason": {"type": "string"},
          "scope": {"type": "object"},
          "budget": {"type": "object"},
          "max_pages": {"type": ["integer", "null"]},
          "max_viewports": {"type": ["integer", "null"]},
          "max_minutes": {"type": ["integer", "null"]},
          "degradation_check": {"type": "object"}
        }
      }
    }
  }
}
