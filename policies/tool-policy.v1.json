{
  "policy_version": 1,
  "default_action": "deny",
  "_shared_protected_path_prefixes": [
    "/.claude/hooks/",
    "/.claude/agents/",
    "/.claude/commands/",
    "/.claude/policies/",
    "/.claude/schemas/",
    "/.claude/scripts/",
    "/.claude/settings.json"
  ],
  "_note": "Path prefixes containing '*' use glob-aware matching (fnmatch-style). Use '*/docs/dev/foo-' to match the prefix 'docs/dev/foo-' anywhere under any worktree. Use '/docs/dev/foo-' to anchor at any path that ends with '/docs/dev/foo-' boundary. Shared protected list is the SOLE catch-all for /.claude/ — DO NOT add broad '/.claude/' to denied prefixes; use only the explicit subdirs above so legitimate worktree artifact paths (e.g. /root/.claude/worktrees/X/docs/dev/...) remain writable.",
  "roles": {
    "user": {
      "allowed_tools": [
        "mcp__playwright__*",
        "Read",
        "Glob",
        "Grep",
        "Bash",
        "Write"
      ],
      "allowed_path_prefixes": [
        "/CLAUDE.md",
        "/README.md",
        "/.env"
      ],
      "denied_path_prefixes": [
        "/src/",
        "/app/",
        "/lib/",
        "/components/"
      ],
      "rationale": "User simulation: Playwright/read for user-flow testing, plus report and own cp-state updates for checklist-stop enforcement; no source/protected/test edits",
      "allowed_write_path_prefixes": [
        "*/docs/dev/user-",
        "*/docs/dev/user-report-",
        "*/docs/dev/overnight/",
        "*/docs/dev/specs/*/user-",
        "*/docs/dev/specs/*/cp-state-user.json",
        "*/.claude/specs/*/cp-state-user.json"
      ],
      "denied_write_path_prefixes": [
        "/src/",
        "/app/",
        "/lib/",
        "/.claude/hooks/",
        "/.claude/agents/",
        "/.claude/commands/",
        "/.claude/policies/",
        "/.claude/schemas/",
        "/.claude/scripts/",
        "/.claude/settings.json",
        "/tests/"
      ]
    },
